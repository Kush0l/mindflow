# Google Gemini API Key
# Get yours at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Neon Postgres Database URL
# Copy this from your Neon dashboard
DATABASE_URL=postgresql://user:password@ep-host.us-east-2.aws.neon.tech/neondb?sslmode=require

# Frontend URL for strict CORS security (Use your Vercel deployment URL in production)
FRONTEND_URL=http://localhost:5173

# Secret for JSON Web Tokens
JWT_SECRET=your_super_secret_jwt_key_here
